# NetZeroIQ Backend environment variables

# Profile
SPRING_PROFILES_ACTIVE=dev
# Use prod on Render:
# SPRING_PROFILES_ACTIVE=prod

# Server
PORT=8000

# Dev/local H2 profile
H2_DATABASE_URL=jdbc:h2:file:./data/netzeroiq-dev;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE;DEFAULT_NULL_ORDERING=HIGH
H2_DATABASE_USERNAME=sa
H2_DATABASE_PASSWORD=
H2_CONSOLE_ENABLED=true

# Prod/PostgreSQL profile - set these in Render environment variables, not in code
DATABASE_URL=jdbc:postgresql://your-host:5432/your-db
DB_USER=your_database_user
DB_PASSWORD=your_database_password

# JWT - set a strong secret in production, minimum 32 characters
JWT_SECRET=replace_with_a_strong_256_bit_secret

# CORS - use your deployed frontend URL in production
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Seed/demo data
# Dev default is true. Prod default is false.
APP_SEED_ENABLED=true
APP_SEED_ANALYST_PASSWORD=analyst@1234
APP_SEED_REVIEWER_PASSWORD=reviewer@1234
APP_SEED_ADMIN_PASSWORD=admin@1234
